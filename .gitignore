# ---------------------------------------------------------------------------
# Unreal Engine project ignore rules
# The .uproject lives in the nested RogueSmoke/ folder, so these patterns are
# written to match at any depth (no leading slash anchor).
# ---------------------------------------------------------------------------

# Generated / build output
Binaries/
DerivedDataCache/
Intermediate/
Saved/
Build/
Build/Receipts/

# Editor / IDE
.vs/
.vscode/
.idea/
.ai/
# generated by ue-cpp MCP (per-machine clangd config)
.clangd
*.VC.db
*.VC.opendb
*.opensdf
*.sdf
*.sln
*.suo
*.xcodeproj
*.xcworkspace
.vsconfig

# Compiled binaries
*.dll
*.exe
*.lib
*.pdb
*.so
*.dylib
*.app
*.ipa

# OS cruft
.DS_Store
Thumbs.db
desktop.ini

# Crash / log artifacts
*.log
*.tmp

# AngelScript: keep source (.as) but ignore any generated/precompiled output
Script/**/*.tmp
# Unanchored (no leading/internal-slash anchor) so they match the nested RogueSmoke/Script/ too.
Binds.Cache
Binds.Cache.Headers

# Obsidian vault config (per-user notes UI state, not project source)
.obsidian/
.superpowers/
